generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserTheme {
  LIGHT_BUSINESS
  DARK_ELECTRIC
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  passwordHash String
  displayName String?
  accountRole String?  // worker | employer (app-level account type)
  theme       UserTheme @default(LIGHT_BUSINESS)
  sessionVersion Int    @default(0)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  subscriptionStatus   String   @default("inactive") // active, trialing, cancelled, past_due, inactive
  subscriptionEndsAt   DateTime?
  subscriptionCancelAtPeriodEnd Boolean @default(false)
  googleAccessToken    String?  @db.Text
  googleRefreshToken   String?  @db.Text
  pushSubscription     Json?
  isActive    Boolean  @default(true)
  deactivatedAt DateTime?
  scheduledDeletionAt DateTime?
  pendingDeletionAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships         CompanyMember[]

  @@index([pendingDeletionAt], map: "User_pendingDeletionAt_idx")
  @@index([scheduledDeletionAt], map: "User_scheduledDeletionAt_idx")

  createdJobs         Job[]               @relation("JobCreatedBy")
  jobAssignments      JobAssignment[]
  completedStages     JobStage[]              @relation("StageCompletedBy")
  supervisedStages    JobStage[]              @relation("StageSupervisor")
  stageSubmissions    JobStage[]              @relation("StageSubmittedBy")
  stageApprovals      JobStage[]              @relation("StageApprovedBy")
  stageRejections     JobStage[]              @relation("StageRejectedBy")
  stageSupervisorAssignments JobStage[]       @relation("StageSupervisorAssignedBy")
  stageHistoryEvents  JobStageHistory[]       @relation("StageHistoryActor")
  stageHistoryTargets JobStageHistory[]       @relation("StageHistoryTarget")
  stageNoteEdits      JobStageNoteHistory[]   @relation("StageNoteEditedBy")
  statusChanges       JobStatusHistory[]  @relation("StatusChangedBy")
  auditLogs           AuditLog[]
  idempotencyKeys     IdempotencyKey[]
  verificationTokens  VerificationToken[]
  attendanceSessions  AttendanceSession[]
  vacationRequests    VacationRequest[]     @relation("VacationEmployee")
  vacationDecisions   VacationRequest[]     @relation("VacationDecidedBy")
  budgetItemsAssigned JobBudgetItem[]         @relation("BudgetItemAssignedUser")
  budgetItemsCreated  JobBudgetItem[]         @relation("BudgetItemCreatedBy")
  budgetLaborAssigned JobBudgetLaborItem[]    @relation("BudgetLaborUser")
  budgetLaborCreated  JobBudgetLaborItem[]    @relation("BudgetLaborCreatedBy")
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
}

model Company {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String?  @unique
  apiKeyHash           String?
  billingStatus        String?  // active, inactive, trialing, past_due, cancelled
  subscriptionEndsAt   DateTime?
  deactivatedAt        DateTime?
  scheduledDeletionAt  DateTime?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members              CompanyMember[]

  @@index([scheduledDeletionAt])
  jobs                 Job[]
  jobAssignments       JobAssignment[]
  jobStages            JobStage[]
  jobStageNoteHistory  JobStageNoteHistory[]
  jobStageHistory      JobStageHistory[]
  jobStagePhotos       JobStagePhoto[]
  jobStatusHistory     JobStatusHistory[]
  auditLogs            AuditLog[]
  idempotencyKeys      IdempotencyKey[]
  attendanceSessions   AttendanceSession[]
  vacationRequests     VacationRequest[]
  jobBudgets           JobBudget[]
  jobBudgetItems       JobBudgetItem[]
  jobBudgetLaborItems  JobBudgetLaborItem[]
  notifications        Notification[]
}

model CompanyMember {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  role        String   // owner, admin, staff
  scope       String?  // all, assigned_only, custom
  isActive    Boolean  @default(true)
  invitedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([companyId, role])
  @@index([companyId, isActive])
}

model Job {
  id                String   @id @default(cuid())
  companyId         String
  jobNumber         Int
  customerName      String
  customerPhone     String
  addressCity       String
  addressStreet     String
  addressZip        String?
  addressNotes      String?
  description       String
  preferredFrom     DateTime?
  preferredTo       DateTime?
  priority          String   // normal, important (legacy: urgent, standard, high)
  status            String   // new, scheduled, in_progress, done, cancelled
  statusUpdatedAt   DateTime @default(now())

  createdByUserId   String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  version           Int      @default(1)
  deletedAt         DateTime?

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy         User               @relation("JobCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignments       JobAssignment[]
  stages            JobStage[]
  stageNoteHistory  JobStageNoteHistory[]
  stageHistory      JobStageHistory[]
  statusHistory     JobStatusHistory[]
  budget            JobBudget?
  budgetItems       JobBudgetItem[]
  budgetLaborItems  JobBudgetLaborItem[]

  @@unique([companyId, jobNumber])
  @@index([companyId])
  @@index([companyId, status, createdAt(sort: Desc)])
  @@index([companyId, statusUpdatedAt(sort: Desc)])
  @@index([companyId, createdByUserId])
  @@index([companyId, priority])
  @@index([companyId, deletedAt])
}

model JobAssignment {
  id                String   @id @default(cuid())
  companyId         String
  jobId             String
  userId            String
  assignedByUserId  String?
  assignedAt        DateTime @default(now())

  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job               Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([companyId])
  @@index([jobId])
  @@index([userId])
  @@index([companyId, jobId])
  @@index([companyId, userId])
}

model JobStage {
  id                 String   @id @default(cuid())
  companyId          String
  jobId              String
  name               String
  description        String?
  plannedDate        DateTime?
  status             String   // todo, in_progress, pending_approval, needs_changes, done
  completedAt        DateTime?
  completedByUserId  String?
  workerNote         String?
  sortOrder          Int      @default(0)

  supervisorUserId             String?
  supervisorCanCreateStages    Boolean  @default(false)
  supervisorAssignedAt         DateTime?
  supervisorAssignedByUserId   String?
  submittedForApprovalAt       DateTime?
  submittedByUserId            String?
  approvedAt                   DateTime?
  approvedByUserId             String?
  rejectedAt                   DateTime?
  rejectedByUserId             String?
  rejectionComment             String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  version            Int      @default(1)

  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job                Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  completedBy        User?    @relation("StageCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  supervisor         User?    @relation("StageSupervisor", fields: [supervisorUserId], references: [id], onDelete: SetNull)
  submittedBy        User?    @relation("StageSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  approvedBy         User?    @relation("StageApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy         User?    @relation("StageRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  supervisorAssignedBy User?  @relation("StageSupervisorAssignedBy", fields: [supervisorAssignedByUserId], references: [id], onDelete: SetNull)
  photos             JobStagePhoto[]
  noteHistory        JobStageNoteHistory[]
  history            JobStageHistory[]

  @@index([companyId])
  @@index([jobId])
  @@index([companyId, jobId])
  @@index([companyId, plannedDate])
  @@index([companyId, status])
  @@index([jobId, sortOrder])
  @@index([supervisorUserId])
}

model JobStageHistory {
  id             String   @id @default(cuid())
  companyId      String
  jobId          String
  stageId        String
  eventType      String   // supervisor_assigned, submitted_for_approval, approved, rejected, reopened
  actorUserId    String
  targetUserId   String?
  comment        String?
  metadata       String?  @db.Text
  createdAt      DateTime @default(now())

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage          JobStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  actor          User     @relation("StageHistoryActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  target         User?    @relation("StageHistoryTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([companyId, jobId, stageId, createdAt])
  @@index([stageId, createdAt])
  @@index([actorUserId])
}

model JobStageNoteHistory {
  id             String   @id @default(cuid())
  companyId      String
  jobId          String
  stageId        String
  editedByUserId String
  previousNote   String
  newNote        String
  createdAt      DateTime @default(now())

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage          JobStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  editedBy       User     @relation("StageNoteEditedBy", fields: [editedByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, jobId, stageId, createdAt])
  @@index([stageId, createdAt])
  @@index([editedByUserId])
}

model JobStagePhoto {
  id               String   @id @default(cuid())
  companyId        String
  jobStageId       String
  bucket           String
  objectKey        String
  contentType      String?
  sizeBytes        Int?
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stage            JobStage @relation(fields: [jobStageId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([jobStageId])
  @@index([companyId, jobStageId])
  @@unique([bucket, objectKey])
}

model JobStatusHistory {
  id              String   @id @default(cuid())
  companyId       String
  jobId           String
  fromStatus      String?
  toStatus        String
  changedByUserId String
  reason          String?
  changedAt       DateTime @default(now())

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  changedBy       User     @relation("StatusChangedBy", fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([jobId])
  @@index([companyId, jobId])
  @@index([companyId, changedAt(sort: Desc)])
  @@index([jobId, changedAt(sort: Desc)])
}

model AuditLog {
  id            String   @id @default(cuid())
  companyId     String
  userId        String?
  action        String
  entityType    String
  entityId      String
  data          Json?
  requestId     String?
  createdAt     DateTime @default(now())

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, entityType, entityId])
  @@index([companyId, action])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([requestId])
}

model IdempotencyKey {
  id              String   @id @default(cuid())
  companyId       String?
  userId          String
  endpoint        String
  idempotencyKey  String
  requestHash     String?
  responseCode    Int?
  responseBody    Json?
  status          String   // started, completed, failed
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  company         Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint, idempotencyKey])
  @@index([companyId])
  @@index([userId])
  @@index([endpoint])
  @@index([expiresAt])
  @@index([companyId, endpoint])
}

model VerificationToken {
  id             String   @id @default(cuid())
  userId         String
  purpose        String
  tokenHash      String
  expiresAt      DateTime
  failedAttempts Int      @default(0)
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([purpose])
  @@index([expiresAt])
  @@index([tokenHash])
  @@index([userId, purpose, createdAt], map: "VerificationToken_userPurposeCreatedAt_idx")
}

/// Daily attendance session per employee (one row per user per day).
model AttendanceSession {
  id                     String    @id @default(cuid())
  companyId              String
  userId                 String
  status                 String    // not_started, working, on_break, finished (legacy: break)
  sessionDate            DateTime  @db.Date
  startedAt              DateTime?
  breakStartedAt         DateTime?
  totalBreakMinutes      Int       @default(0)
  endedAt                DateTime?
  totalWorkedMinutes     Int?
  checkInPhotoUrl        String?
  checkInPhotoExpiresAt  DateTime?
  checkOutPhotoUrl       String?
  checkOutPhotoExpiresAt DateTime?
  managerProofPhotoUrl   String?
  managerProofPhotoExpiresAt DateTime?
  locationText           String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, sessionDate])
  @@index([companyId, sessionDate])
  @@index([companyId, userId, sessionDate])
  @@index([companyId, status])
  @@index([userId])
}

/// Vacation / leave request scoped to company and employee.
model VacationRequest {
  id          String    @id @default(cuid())
  companyId   String
  userId      String
  type        String    // PAID, ON_DEMAND, UNPAID, SICK
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  totalDays   Int
  status      String    // PENDING, APPROVED, REJECTED
  reason      String?
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User    @relation("VacationEmployee", fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User?   @relation("VacationDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([companyId, userId])
  @@index([companyId, startDate])
  @@index([companyId, endDate])
  @@index([companyId, startDate, endDate])
}

/// Owner/admin project cost estimate for a job.
model JobBudget {
  id               String   @id @default(cuid())
  companyId        String
  jobId            String   @unique
  totalBudgetCents Int      @default(0)
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company    Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job        Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  items      JobBudgetItem[]
  laborItems JobBudgetLaborItem[]

  @@index([companyId, jobId])
}

model JobBudgetItem {
  id               String    @id @default(cuid())
  companyId        String
  jobId            String
  budgetId         String
  category         String
  taxCategory      String
  name             String
  netAmountCents   Int?
  vatRate          String?
  grossAmountCents Int
  deductible       Boolean   @default(true)
  documentType     String?
  documentNumber   String?
  supplier         String?
  plannedDate      DateTime?
  assignedUserId   String?
  note             String?
  createdByUserId  String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  budget       JobBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  assignedUser User?    @relation("BudgetItemAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy    User     @relation("BudgetItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, jobId])
  @@index([budgetId])
  @@index([companyId, jobId, createdAt])
  @@index([companyId, jobId, category])
  @@index([companyId, jobId, taxCategory])
}

model JobBudgetLaborItem {
  id               String    @id @default(cuid())
  companyId        String
  jobId            String
  budgetId         String
  userId           String?
  employmentType   String    @default("b2b") // b2b, subcontractor, student_under_26, mandate_contract, employment_contract
  plannedMinutes   Int
  hourlyRateCents  Int
  plannedDate      DateTime?
  note             String?
  createdByUserId  String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  budget    JobBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  user      User?    @relation("BudgetLaborUser", fields: [userId], references: [id], onDelete: SetNull)
  createdBy User     @relation("BudgetLaborCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, jobId])
  @@index([budgetId])
  @@index([companyId, jobId, createdAt])
}

/// Processed Stripe webhook events for idempotent delivery handling.
model StripeWebhookEvent {
  id           String    @id @default(cuid())
  eventId      String    @unique
  eventType    String
  status       String    // processing, processed, failed
  errorMessage String?   @db.Text
  processedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([createdAt])
  @@index([status])
}

/// In-app notification history for a user (DB is source of truth; push is best-effort delivery).
model Notification {
  id        String    @id @default(cuid())
  userId    String
  companyId String?
  type      String
  title     String
  body      String
  url       String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@index([companyId])
}

/// Web Push subscription per user device/browser (multi-device).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
